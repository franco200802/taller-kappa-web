# ============================================
# TALLER KAPPA — Environment Variables
# Copy this file as .env and fill in the values
# ============================================

# MongoDB Atlas connection string (free tier: mongodb.com/atlas)
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/tallerkappa
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/tallerkappa

# MercadoPago credentials (mercadopago.com.ar/developers)
# Use TEST credentials first, switch to PROD when ready
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxx-xxxxxxxxx

# Frontend URL (for CORS and MercadoPago redirects)
# Local: http://localhost:5500  |  Prod: https://tallerkappa.com.ar
FRONTEND_URL=https://tallerkappa.com.ar

# Port (Render sets this automatically)
PORT=3000
